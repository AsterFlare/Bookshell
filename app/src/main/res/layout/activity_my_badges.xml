<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- TOP BAR -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/title_my_badges"
        app:titleTextColor="#0B5C8E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="More options" />
    </com.google.android.material.appbar.MaterialToolbar>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- COLLECTOR LEVEL CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#CCEDF9">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toStartOf="@id/level_circle">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/collector_level_label"
                            android:textColor="#805A5B61"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_badge_sea_mover"
                            android:textColor="#0B5C8E"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/badges_earned_status"
                            android:textColor="#0B5C8E"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <ProgressBar
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="200dp"
                            android:layout_height="12dp"
                            android:layout_marginTop="8dp"
                            android:progress="66"
                            android:progressDrawable="@drawable/bg_progress_bar" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/level_circle"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@color/white">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="4"
                            android:textColor="#1E88E5"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BADGES GRID -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:useDefaultMargins="true">

                <!-- Badge 1 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="64dp" android:layout_height="64dp"
                                android:background="#1E88E5" android:padding="12dp"
                                android:src="@drawable/librarynav" app:tint="@color/white"
                                app:shapeAppearanceOverlay="@style/ShapeAppearance.RoundedCircle" />
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="top|end" android:src="@drawable/ic_check_circle" app:tint="#CDB395"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="12dp" android:text="@string/badge_first_voyage"
                            android:textColor="#1A1C1E" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/desc_first_voyage" android:textColor="#5A5B61" android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Badge 2 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="64dp" android:layout_height="64dp"
                                android:background="#E67E22" android:padding="12dp"
                                android:src="@drawable/communitynav" app:tint="@color/white"
                                app:shapeAppearanceOverlay="@style/ShapeAppearance.RoundedCircle" />
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="top|end" android:src="@drawable/ic_check_circle" app:tint="#CDB395"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="12dp" android:text="@string/badge_tidal_curator"
                            android:textColor="#1A1C1E" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/desc_tidal_curator" android:textColor="#5A5B61" android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Badge 3 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="64dp" android:layout_height="64dp"
                                android:background="#87CEFA" android:padding="12dp"
                                android:src="@android:drawable/btn_star_big_on" app:tint="@color/white"
                                app:shapeAppearanceOverlay="@style/ShapeAppearance.RoundedCircle" />
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="top|end" android:src="@drawable/ic_check_circle" app:tint="#CDB395"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="12dp" android:text="@string/badge_starfish_rater"
                            android:textColor="#1A1C1E" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/desc_starfish_rater" android:textColor="#5A5B61" android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Badge 4 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="64dp" android:layout_height="64dp"
                                android:background="#0B5C8E" android:padding="12dp"
                                android:src="@drawable/librarynav" app:tint="@color/white"
                                app:shapeAppearanceOverlay="@style/ShapeAppearance.RoundedCircle" />
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="top|end" android:src="@drawable/ic_check_circle" app:tint="#CDB395"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="12dp" android:text="@string/badge_novice_reader"
                            android:textColor="#1A1C1E" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/badge_novice_count" android:textColor="#5A5B61" android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Badge 5 (Locked) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="64dp" android:layout_height="64dp"
                            android:background="#F0F2F5" android:padding="16dp"
                            android:src="@drawable/ic_logo" app:tint="#BDBDBD"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.RoundedCircle" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="12dp" android:text="@string/badge_bookworm"
                            android:textColor="#BDBDBD" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/badge_bookworm_count" android:textColor="#BDBDBD" android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Badge 6 (Locked) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:gravity="center"
                        android:orientation="vertical">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="64dp" android:layout_height="64dp"
                            android:background="#F0F2F5" android:padding="16dp"
                            android:src="@drawable/ic_logo" app:tint="#BDBDBD"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.RoundedCircle" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="12dp" android:text="@string/badge_ancient_pearl"
                            android:textColor="#BDBDBD" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/desc_ancient_pearl" android:textColor="#BDBDBD" android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- DETAIL CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="48dp" android:layout_height="48dp"
                        android:background="#CCEDF9" android:padding="12dp"
                        android:src="@drawable/ic_info" app:tint="#1E88E5"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Rounded12" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/badge_detail_title" android:textColor="#0B5C8E"
                            android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" android:text="@string/badge_detail_desc"
                            android:textColor="#5A5B61" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
