<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/badgeCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:strokeColor="#12000000"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="176dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="12dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivBadgeIcon"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center_horizontal"
                android:background="@android:color/transparent"
                android:padding="0dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/badge_icon_desc"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.RoundedCircle" />

            <ImageView
                android:id="@+id/ivBadgeCheck"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-2dp"
                android:layout_marginEnd="-2dp"
                android:src="@drawable/ic_check_circle"
                android:contentDescription="@string/checkmark_desc"
                android:visibility="gone"
                app:tint="@color/save_button_bg"
                tools:visibility="visible" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvBadgeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="40dp"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="#1A1C1E"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.01"
            tools:text="First Voyage" />

        <TextView
            android:id="@+id/tvBadgeStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:textSize="11sp"
            tools:text="Unlocked" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
